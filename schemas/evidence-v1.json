{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schemas/evidence-v1.json",
  "title": "Canonical Verification Evidence v1",
  "description": "Structural schema for verification evidence files stored under artifacts/verification/<commit-sha>/.",
  "$comment": "This schema defines structural constraints only. Gate-context checks such as commit_sha matching the evaluated commit, test_type matching the evidence file name, status=passed acceptance, e2e artifact non-emptiness, and stats arithmetic consistency remain enforced by scripts/verification/validate-gate.sh.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project",
    "change",
    "commit_sha",
    "test_type",
    "status",
    "started_at",
    "finished_at",
    "source",
    "stats"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "change": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "test_type": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "e2e"
      ]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "finished_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "workflow",
        "run_id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "workflow": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "skipped"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
