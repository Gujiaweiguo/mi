    private void TransDetails()
    {
        string strSku;
        decimal curQty, curOrg_price;
        decimal curNew_price;
        string strFlag, strTax_cd;
        string strDisc_cd;
        decimal curDisc_amt;
        string strDept;
        string strCatg, strLabelkey, strComm_ind;
        decimal curNet_amt, curDisc_by;
        string strDesc_sign;
        decimal curItem_gst, lngTax;
        string strPluCd;
        string strSql;
        long lngTransId;
        decimal AllocDisc;
        string ClassCd = "";

        //lngTransId = Convert.ToInt64(TranId());decimal strTransNo                //TransId
        lngTransId = Convert.ToInt64(strTransNo);
        strSku = NextToken();          //SkuCd
        curQty = Convert.ToInt32(NextToken());             //Qty
        curOrg_price = Convert.ToDecimal(NextToken());       //Org_price
        curNew_price = Convert.ToDecimal(NextToken());       //New_Preice
        strFlag = NextToken();                 //SkuFlag
        strTax_cd = NextToken();              //TaxCd
        strDisc_cd = NextToken();              //DiscCd
        curDisc_amt = Convert.ToDecimal(NextToken());        //ItemDisc
        strDept = NextToken();                //DeptCd
        strCatg = NextToken();              //CatgCd
        NextToken();
        strComm_ind = NextToken().Substring(0,1);    // Mid(NextToken, 1, 1)  //PayComm
        curNet_amt = Convert.ToDecimal(NextToken());              //NetAmt
        NextToken();
        NextToken();
        lngTax = Convert.ToDecimal(NextToken());                //Tax
        strPluCd = NextToken();                //PluCd
        AllocDisc = 0;

        strSql = "INSERT INTO TransDetail VALUES" 
                    +"(" 
                    +lngTransId + "," 
                    +"'" + strSku + "'," 
                    +"'" + strPluCd + "'," 
                    +"'" + strDept + "'," 
                    +"'" + strCatg + "'," 
                    +"'" + ClassCd + "'," 
                    +"'" + strTax_cd + "'," 
                    +curQty + "," 
                    +curOrg_price + "," 
                    +curNew_price + "," 
                    +"'" + strFlag + "'," 
                    +"'" + strDisc_cd + "'," 
                    +curDisc_amt + "," 
                    +AllocDisc + "," 
                    +lngTax + "," 
                    +curNet_amt + "," 
                    +"'" + strComm_ind + "'" 
                    +")";
        //BaseBO baseBo = new BaseBO();
        baseTrans.ExecuteUpdate(strSql);

        if (strTraining == "Y")
        {
            return;
        }
        curItemDisc = curItemDisc + curDisc_amt;
    }

    private void TransMedia()
    {
        string strMedia_type, strMedia_name;
        string strCurr_cd;
        double dblCurr_rate;
        decimal curAmount;
        string strRemarks1, strRemarks2;
        decimal curBase_amt;
        long lngTransId;
        string strRemarks3, strEFTID,strSql;
        decimal curComTenant=0, curComAmt=0;

        //lngTransId = Convert.ToInt64(TranId());                     //TransId
        lngTransId = Convert.ToInt64(strTransNo);
        strMedia_type = NextToken();               //Media Type
        strMedia_name = NextToken();               //Media Cd
        strCurr_cd = NextToken();                  //CurrCd
        dblCurr_rate = Convert.ToDouble(NextToken());          //ExcRate
        curAmount = Convert.ToDecimal(NextToken());             //Amount
        strRemarks1 = NextToken().Trim();
        strRemarks2 = NextToken().Trim();
        strRemarks3 = NextToken().Trim();
        curBase_amt = Convert.ToDecimal(NextToken());

        strSql = "INSERT INTO TransMedia (TransId,MediaType,MediaCd,CurrCd,ExcRate,Amountt,LocalAmt,Remark1,Remark2,Remark3) VALUES " 
                   +"(" 
                   +lngTransId + ", " 
                   +"'" + strMedia_type + "', " 
                   +"'" + strMedia_name + "', " 
                   +"'" + strCurr_cd + "', " 
                   +dblCurr_rate + ", " 
                   +curAmount + "," 
                   +curBase_amt + "," 
                   +"'" + strRemarks1 + "', " 
                   +"'" + strRemarks2 + "'," 
                   +"'" + strRemarks3 + "'" 
                   +")";

        //BaseBO baseBo = new BaseBO();
        baseTrans.ExecuteUpdate(strSql);

        if((strRemarks1 != "")&&(strRemarks3 != "")&&((strRemarks2 == "4")||(strRemarks2 == "5")))
        {
            if(strMedia_type == "T")
            {
                curComTenant = getComTenant(strMedia_name, strCurr_cd);
                curComAmt = curBase_amt * curComTenant / 100;
            }
            else
            {
                curComTenant = 0;
                curComAmt = 0;
            }
        }
        strEFTID = strEFTPrefix + strRemarks3;

        strSql = "INSERT INTO TransCard (TransId,EFTId,CardId,BizDate,Amt,MediaType,MediaCd,ReconcId,TransType,ComTenant,ComAmt) VALUES " 
                        +"(" 
                        +lngTransId + "," 
                        +"'" + strEFTID + "'," 
                        +"'" + strRemarks1 + "'," 
                        +"'" + Convert.ToDateTime(strBizDate) + "'," 
                        +curBase_amt + "," 
                        +"'" + strMedia_type + "'," 
                        +"'" + strMedia_name + "'," 
                        +0 + "," 
                        +"'" + strRemarks2 + "'," 
                        +curComTenant + "," 
                        +curComAmt 
                        +")";
        baseTrans.ExecuteUpdate(strSql);

        if(strMedia_type == "T") //Kan(021018)
        {
            curTransTotal = curTransTotal + Convert.ToInt32(curBase_amt);
        }
        else
        {
            curTransTotal = curTransTotal -  Convert.ToInt32(curBase_amt);
        }
    }

    private void TransBonus()
    {
        long lngTransId;

        blnTransBonus = true;
        //lngTransId = Convert.ToInt64(TranId());            //TransID
        lngTransId = Convert.ToInt64(strTransNo);
        strLCardId = NextToken();          //LCardID
        strLCard = strLCardId;
        curBonusAmt = Convert.ToDecimal(NextToken());         //Bonus Amount

    //TransBonus
        string strSql = "INSERT INTO TransBonus VALUES" 
                    +"(" 
                    +lngTransId + "," 
                    +"'" + strLCardId + "'," 
                    +curBonusAmt + "" 
                    +")";
        //BaseBO baseBo = new BaseBO();
        baseTrans.ExecuteUpdate(strSql);
    }

    private decimal getComTenant(string strMediaCd,string strCurr_cd)
    {
        string otherBank = (String)GetGlobalResourceObject("BaseInfo", "Sale_OtherBank");
        decimal getcomTenant;
        BaseBO baseBo = new BaseBO();
        string strSql = "SELECT ComTenant From MediaM WHERE MediaMDesc='" + strMediaCd + "'";
        DataSet ds = baseBo.QueryDataSet(strSql);
        if (ds.Tables[0].Rows.Count > 0)
        {
            getcomTenant = Convert.ToDecimal(ds.Tables[0].Rows[0][0]);
            return getcomTenant;
        }
        if(strCurr_cd.Trim() == "RMB")
        {
            strSql = "SELECT ComTenant From MediaM WHERE MediaMDesc= '" + otherBank + "'";
        }
        else
        {
            strSql = "SELECT ComTenant From MediaM WHERE MediaMDesc='" + otherBank + "'";
        }
        ds.Clear();
        ds = baseBo.QueryDataSet(strSql);
        getcomTenant = Convert.ToDecimal(ds.Tables[0].Rows[0][0]);
        return getcomTenant;
    }

    private void GetEFTPrefixID()
    {
        string strSql = "SELECT EFTPrefix FROM PpPara";
        BaseBO baseBo = new BaseBO();
        DataSet ds = baseBo.QueryDataSet(strSql);
        strEFTPrefix = ds.Tables[0].Rows[0]["EFTPrefix"].ToString();
    }

