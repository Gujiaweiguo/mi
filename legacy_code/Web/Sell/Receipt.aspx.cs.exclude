    private void DailySales()
    {
        int i;
        string strdattemp;
        strdattemp = "";
        for(i=1;i<strDat.Length;i++)
        {
            strdattemp = strdattemp + "'" + Convert.ToDateTime(strDat[i]).ToString("YYYY-MM-DD") + "',";
        }
        strdattemp = strdattemp.Substring(0,strdattemp.Trim().Length-1);
        bAutoCreate = true;
        BaseTrans baseTrans = new BaseTrans();
        baseTrans.BeginTrans();
        string strSql = "Delete From DailySales WHERE bizDate IN (" + strdattemp + ") ";
        try
        {
            baseTrans.ExecuteUpdate(strSql);
        }
        catch(Exception ex)
        {
            baseTrans.Rollback();
            Response.Write(ex.ToString());
        }
        baseTrans.Commit();

        baseTrans.BeginTrans();
        strSql = "INSERT INTO dailysales " 
            +"SELECT transHeader.tenantID, " 
            +"transHeader.posID, " 
            +"transHeader.bizDate, " 
            +"transHeader.batchID, " 
            +"MIN(CAST(transHeader.ReceiptID AS INTEGER)) AS OReceipt, " 
            +"MAX(CAST(transHeader.ReceiptID AS INTEGER)) AS CReceipt,  " 
            +"(count( Distinct transFooter.transID )) AS TotalReceipt, " 
            +"SUM(transFooter.totalAmt +  transFooter.ReceiptDisc) AS GrossSales, " 
            +"0 AS Tax,0 AS MiscTax,0 AS SerCharge,0 AS MiscCharge, " 
            +"SUM(transFooter.ReceiptDisc) AS Discount, " 
            +"SUM(transFooter.totalAmt) AS netSales, " 
            +"getdate() AS entryAt, " 
            +"'SYS' AS entryBy,'N' AS ManualEntry " 
            +"FROM transHeader INNER JOIN " 
            +"transFooter ON (transHeader.transID = transFooter.transID) " 
            +"WHERE transHeader.training = 'N' " 
            +"AND transHeader.bizDate IN (" + strdattemp + ") " 
            +"AND EXISTS (SELECT 1 FROM leaseUnit WHERE leaseUnit.tenantID = transHeader.tenantID) " 
            +"GROUP BY transHeader.tenantID,transHeader.posID,transHeader.bizDate,TransHeader.batchID";
        try
        {
            baseTrans.ExecuteUpdate(strSql);
        }
        catch(Exception ex)
        {
            baseTrans.Rollback();
            Response.Write(ex.ToString());
        }
        baseTrans.Commit();
    }

