    protected void Button1_Click(object sender, EventArgs e)
    {
        doWithFile();  //上传销售数据
        strDefaultDir = FileUpload1.PostedFile.FileName;
        string[] Names = strDefaultDir.Split(new char[] { '\\' });
        strFileNm = Names[Names.Length - 1];
        iNum = 0;
        OpenTextFile();
        StartImportData();
        //DailySales();

    }

    private string NextToken()
    {
        int i;
        int j;
        string str1 = "";
        string str2 = "";
        PstrDel = "|";
        string nextToken;

        PlngFoundPos = PstrRec.IndexOf(PstrDel,PlngStartPos);
        if (PlngFoundPos > 0)
        {
            nextToken = PstrRec.Substring(PlngStartPos, PlngFoundPos - PlngStartPos);
            PlngStartPos = PlngFoundPos + 1;
        }
        else
        {
            nextToken = PstrRec.Substring(PlngStartPos, PstrRec.Length - PlngStartPos);
        }

        for (i = 0; i < nextToken.Length; i++)
        {
            if(nextToken.Substring(i,1) == "''")
            {
                nextToken.Substring(i, 1).Replace("''"," ");
            }
            else if (nextToken.Substring(i, 1) == "'")
            {
                nextToken.Substring(i, 1).Replace("'"," ");
            }
        }
        return nextToken;
    }

    private void OpenTextFile()
    {
        string strTemp;
        String input = "";
        if (strFileNm.Substring(0,1).ToString().ToUpper() != "T")
        {
            return;
        }
        sr = new StreamReader(vsurl, Encoding.GetEncoding("gb2312"));
        PlngStartPos = 0;
        PstrRec = sr.ReadLine();
        if (NextToken() != "1")
        {
            return;
        }
        NextToken();
        strShopNo = NextToken();
        if (CheckTenantID(strShopNo) == false)
        {
            if (strShopNo.Trim() == "1")
            {
                return;
            }
            return;
        }
        strBatchId = NextToken();
        NextToken();
        NextToken();
        NextToken();
        strTemp = NextToken();
        datBizDate = Convert.ToDateTime(strTemp);// strTemp.Substring(0, 4) + "-" + strTemp.Substring(4, 2) + "-" + strTemp.Substring(6, 2);
        //while (sr.Peek() > 0)
        //{
        //    sr.ReadLine();
        //}
        //NextToken();
        //NextToken();
        //NextToken();
        //NextToken();



    }

    private bool CheckTenantID(string strTenantID)
    {
        bool checkTenantID;
        BaseBO baseBo = new BaseBO();
        string strSql = "SELECT ShopId,AreaId,BuildingID,BrandID,UnitTypeID,ContractID,FloorID,LocationID,CreateUserID,CreateTime,ModifyUserID,"+
                    "ModifyTime,OprRoleID,OprDeptID,ShopCode,ShopName,RefID,RentArea,ShopStatus,ShopTypeID,ShopStartDate,ShopEndDate,ContactorName,Tel" +
                    " FROM ConShop where ShopID = '" + strTenantID.Trim() + "'";
        DataSet ds = baseBo.QueryDataSet(strSql);
        if (ds.Tables[0].Rows.Count <= 0)
        {
            checkTenantID = false;
        }
        else
        {
            checkTenantID = true;
        }
        return checkTenantID;
    }

    private void StartImportData()
    {
        
        baseTrans.BeginTrans();
        try
        {
            curTransTotal = 0;
            while (sr.Peek() > 0)
            {
                PstrRec = sr.ReadLine();
                PlngStartPos = 0;
                string strTemp = NextToken();
                switch (strTemp)
                {
                    case "1":
                        if (curTransTotal != 0)
                        {
                            Previous_TransFooter();
                        }
                        TransBatch();
                        break;
                    case "101":
                        if (curTransTotal != 0)
                        {
                            Previous_TransFooter();
                        }
                        TransHeader();
                        break;
                    case "102":
                        TransProfile();
                        break;
                    case "103":
                        TransContact();
                        break;
                    case "111":
                        TransDetails();
                        break;
                    case "131":
                        TransMedia();
                        break;
                    case "161":
                        TransBonus();
                        break;
                    default:
                        break;

                }
            }
        }
        catch(Exception ex)
        {
            baseTrans.Rollback();
            Response.Write(ex.ToString());
        }
        baseTrans.Commit();
        //AuditDetails();
    }

    private string TranId()
    {
        string strSql = "SELECT Max(TransId) From TransHeader";
        BaseBO baseBo = new BaseBO();
        DataSet ds = baseBo.QueryDataSet(strSql);
        string tranId = ds.Tables[0].Rows[0][0].ToString();
        return tranId;
    }

    private void Previous_TransFooter()
    {
        decimal curGross_amt,curDiscount,curCess,curServ_chg,curTax,curNetSales,curOther_chg,curNetAmount;
        string strPrice_method,strTax_exampted,strDiscount_cd;
        long lngTransId;

        //lngTransId = Convert.ToInt64(TranId());
        lngTransId = Convert.ToInt64(strTransNo);
        curGross_amt = curTransTotal;              
        curDiscount = 0;                          
        curNetAmount = curTransTotal;
        curCess = 0;                                
        curServ_chg = 0;                            
        curTax = 0;                                   
        strPrice_method = "E";                      
            
        curNetSales = curTransTotal;
        string lCustID = strLCustID();
        
        strTax_exampted = "N";                 
        strDiscount_cd = " ";                
        curOther_chg = 0;

        curTransTotal = 0;  
  
         string strSql = "INSERT INTO TransFooter VALUES ("+lngTransId+","+curGross_amt+","+curDiscount+",'"+strDiscount_cd+"',"+curTax
                    +",'"+strPrice_method+"','"+strTax_exampted+"',"+curCess+","+curOther_chg+","+curServ_chg+")";
         //BaseBO baseBo = new BaseBO();
         baseTrans.ExecuteUpdate(strSql);

         if (blnTransBonus == true)
         {
             string strSql1 = "INSERT INTO PurCurr VALUES (" + lngTransId + ",'" + strShopNo + "','" + datTHeader + "','" + strLCardId + "','" + lCustID + "',"
                        +curNetSales+","+curBonusAmt+",'"+DateTime.Now+"','"+strUserNm+"')";

             baseTrans.ExecuteUpdate(strSql1);
            strLCardId = "";
            curBonusAmt = 0;
         }

         blnTransBonus = false;
         if (strTraining == "Y")
             return;
         curTottalAmt = curTottalAmt + curGross_amt;
         curDiscount = curDiscount + curDiscount;
         curTotNetSales = curTotNetSales + curNetSales;
         curTotCess = curTotCess + curCess;
         curTotServChg = curTotServChg + curServ_chg;
         curTotTax = curTotTax + curTax;
         curTotOtherChg = curTotOtherChg + curOther_chg;
        if ((strTraining == "N" )&&(strTranStatus == "SALE"))
        {
            intTransCount = intTransCount + 1;
        }
         
    }

    private void TransBatch()
    {
        DateTime datStEntryAt;
        string strEntryBy;
        string strFRecipId,strRecordType,strRecipId;
        string D,T,strSql;
        DateTime dtmDate_time;

        strRecordType = NextToken();
        strShopNo = NextToken();
        strPosNo = NextToken();
        strRecipId = NextToken();
        strBatchId = NextToken();
        D = NextToken();
        T = NextToken();
        D = D.Substring(0, 4) + "-" + D.Substring(4, 2) + "-" + D.Substring(6, 2);
        string DT = D +" "+ T;
        dtmDate_time = DateTime.Parse(DT);
        strEntryBy = strUserNm;
        datStEntryAt = DateTime.Now;
        //BaseBO baseBo = new BaseBO();
        if (strRecordType == "OPENED".ToUpper())
        {
            strSql = "INSERT INTO TransBatch (TenantId,PosId,BizDate,BatchId,FReceiptId,LReceiptId,StartAt,EntryBy) VALUES "
                       + "(" 
                       +"'" + strShopNo + "', " 
                       +"'" + strPosNo + "'," 
                       +"'" + datBizDate + "'," 
                       +"'" + strBatchId + "'," 
                       +"'" + strRecipId + "'," 
                       +"'" + " '," 
                       +"'" + datStEntryAt + "'," 
                       +"'" + strUserNm + "'" 
                       +")";

            baseTrans.ExecuteUpdate(strSql);
            curTottalAmt = 0;
            curDiscount = 0;
            curTotNetSales = 0;
            curTotCess = 0;
            curTotServChg = 0;
            curTotTax = 0;
            curTotOtherChg = 0;
            intTransCount = 0;
            curItemDisc = 0;
        }
        else
        {
            strSql = "Update TransBatch Set LReceiptId ='" + strRecipId + "'," 
                        + " EndAt ='" + datStEntryAt + "'" 
                        + " WHERE TenantId = '" + strShopNo + "'" 
                        + " AND PosId = '" + strPosNo + "'" 
                        + " AND BizDate = '" + datBizDate + "'" 
                        + " AND BatchId = '" + strBatchId + "'";
            baseTrans.ExecuteUpdate(strSql);
        }
    }

    private void TransHeader()
    {
        int intShift_no;
        DateTime dtmDate_time;
        string strUser_id, strReceiptId;
        string strMReceipt,strRReceipt;
        string strReason,strSalesman;
        string strTable_no,intGuestCount;
        string D, T, strSql;

        strReceiptId = NextToken();
        intShift_no = Convert.ToInt32(NextToken());
        D = NextToken();
        T = NextToken();
        
        D = D.Substring(0, 4) + "-" + D.Substring(4, 2) + "-" + D.Substring(6, 2);
        string DT = D + " " + T;
        dtmDate_time = DateTime.Parse(DT);
        strBizDate = D;
        CheckDate(strBizDate);
        datTHeader = dtmDate_time;
        strUser_id = NextToken();
        strMReceipt = NextToken();
        strRReceipt = NextToken();
        strReason = NextToken();
        strSalesman = NextToken();
        NextToken();
        intGuestCount = NextToken();
        strTraining = NextToken().ToUpper();
        strTranStatus = NextToken().ToUpper();
        if ((strTranStatus.ToUpper() != "SALE") && (strTranStatus.ToUpper() != "SIGNON") && (strTranStatus.ToUpper() != "SIGNOFF"))
        {
            return;
        }
        strTransNo = Convert.ToDecimal(BaseApp.GetTransID());
        strSql = "INSERT INTO TransHeader VALUES " 
                    +"("
                    + "'" + strTransNo + "'," 
                    +"'" + strShopNo + "'," 
                    +"'" + strPosNo + "'," 
                    +"'" + strBizDate + "'," 
                    +"'" + strBatchId + "'," 
                    +"'" + strReceiptId + "'," 
                    +"'" + intShift_no + "'," 
                    +"'" + dtmDate_time + "', " 
                    +"'" + strUser_id + "'," 
                    +"'" + strMReceipt + "'," 
                    +"'" + strRReceipt + "'," 
                    +"'" + strReason + "'," 
                    +"'" + strSalesman + "'," 
                    +intGuestCount + "," 
                    +"'" + strTraining + "'," 
                    +"'" + strTranStatus + "'," 
                    +"'" + DateTime.Now + "'," 
                    +"'" + strUserNm + "'" 
                    +")";
        //BaseBO baseBo = new BaseBO();
        baseTrans.ExecuteUpdate(strSql);
    }

