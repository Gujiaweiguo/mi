# =============================================================================
# MI Development Environment Configuration
# =============================================================================
# Usage: docker compose --env-file deploy/env/dev.env \
#          -f deploy/compose/docker-compose.dev.yml up mysql
#
# Or for full-stack dev:
#        docker compose --env-file deploy/env/dev.env \
#          -f deploy/compose/docker-compose.dev.yml --profile fullstack up

# --- External Ports ---
# Host port for backend API
MI_HTTP_PORT=5180
# Host port for MySQL (matches container default)
MI_DB_PORT=3306
# Host port for Vite dev server (frontend)
MI_FRONTEND_PORT=5173

# --- Database (MySQL container init) ---
MI_DB_NAME=mi_dev
MI_DB_USER=mi_dev
MI_DB_PASSWORD=devpassword

# --- Auth ---
# JWT secret for local development only — never use in production
MI_JWT_SECRET=dev-secret-change-in-production

# --- Logging ---
MI_LOG_LEVEL=debug

# --- Backend Server ---
MI_SERVER_HOST=0.0.0.0
MI_SERVER_PORT=5180
