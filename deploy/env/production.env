# =============================================================================
# MI Production Environment Configuration
# =============================================================================
# Usage: docker compose --env-file deploy/env/production.env \
#          -f deploy/compose/docker-compose.production.yml up -d
#
# IMPORTANT: Replace all "change-me" values before deploying to production.
# This committed file is a template only; do not treat it as a deploy-safe secret source.

# --- External Ports ---
MI_HTTP_PORT=80

# --- Database (used by MySQL container init + compose variable substitution) ---
MYSQL_DATABASE=mi_prod
MYSQL_USER=mi_prod
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root

# --- Database (used by backend via Viper env binding) ---
# `MI_DATABASE_PASSWORD` must be replaced before any rehearsal/go-live run.
MI_DATABASE_HOST=mysql
MI_DATABASE_PORT=3306
MI_DATABASE_NAME=mi_prod
MI_DATABASE_USER=mi_prod
MI_DATABASE_PASSWORD=change-me
MI_DATABASE_SSL_MODE=disable

# --- Auth ---
# `MI_AUTH_JWT_SECRET` must be replaced before any rehearsal/go-live run.
MI_AUTH_JWT_SECRET=change-me-production-secret
MI_AUTH_TOKEN_EXPIRY_SECONDS=3600

# --- Logging ---
MI_LOG_LEVEL=info

# --- Backend Server ---
MI_SERVER_HOST=0.0.0.0
MI_SERVER_PORT=5180
MI_SERVER_READ_TIMEOUT_SECONDS=15
MI_SERVER_WRITE_TIMEOUT_SECONDS=15
MI_BACKEND_CONFIG_FILE=/app/config/production.yaml

# --- Storage (container paths, mapped via volumes) ---
MI_STORAGE_GENERATED_DOCUMENTS_PATH=/app/generated-documents
MI_STORAGE_UPLOADS_PATH=/app/uploads
MI_STORAGE_LOGS_PATH=/app/logs

# --- Runtime Host Paths (volume mount sources) ---
# Backend container runs as uid 10001 (`appuser`). Ensure these paths are
# writable for that uid before running production smoke/rehearsal commands.
MI_RUNTIME_BASE=../runtime/production
MI_RUNTIME_LOGS=../runtime/production/logs
MI_RUNTIME_DOCUMENTS=../runtime/production/documents
MI_RUNTIME_UPLOADS=../runtime/production/uploads
MI_RUNTIME_MYSQL=../runtime/production/mysql
MI_RUNTIME_CONFIG=../../backend/config

# --- Workflow Reminder Scheduler ---
MI_WORKFLOW_REMINDER_SCHEDULER_ENABLED=false
MI_WORKFLOW_REMINDER_SCHEDULER_INTERVAL_SECONDS=3600
MI_WORKFLOW_REMINDER_SCHEDULER_LOCK_NAME=workflow:reminder:scheduler
MI_WORKFLOW_REMINDER_SCHEDULER_REMINDER_TYPE=standard
MI_WORKFLOW_REMINDER_SCHEDULER_MIN_PENDING_AGE_SECONDS=86400
MI_WORKFLOW_REMINDER_SCHEDULER_WINDOW_TRUNCATION_SECONDS=86400
