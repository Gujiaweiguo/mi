# =============================================================================
# MI Production Environment Configuration
# =============================================================================
# Usage: docker compose --env-file deploy/env/production.env \
#          -f deploy/compose/docker-compose.production.yml up -d
#
# IMPORTANT: Replace all "change-me" values before deploying to production.

# --- External Ports ---
MI_HTTP_PORT=80
MI_MYSQL_PORT=3306

# --- Database ---
MYSQL_DATABASE=mi_prod
MYSQL_USER=mi_prod
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root
MI_DB_HOST=mysql
MI_DB_PORT=3306
MI_DB_NAME=mi_prod
MI_DB_USER=mi_prod
MI_DB_PASSWORD=change-me
MI_DB_SSL_MODE=disable

# --- Auth ---
MI_JWT_SECRET=change-me-production-secret
MI_JWT_TOKEN_EXPIRY_SECONDS=3600

# --- Logging ---
MI_LOG_LEVEL=info

# --- Backend Server ---
MI_SERVER_HOST=0.0.0.0
MI_SERVER_PORT=8080
MI_SERVER_READ_TIMEOUT_SECONDS=15
MI_SERVER_WRITE_TIMEOUT_SECONDS=15
MI_BACKEND_CONFIG_FILE=/app/config/production.yaml

# --- Storage (container paths, mapped via volumes) ---
MI_STORAGE_DOCUMENTS=/app/generated-documents
MI_STORAGE_UPLOADS=/app/uploads
MI_STORAGE_LOGS=/app/logs

# --- Runtime Host Paths (volume mount sources) ---
MI_RUNTIME_BASE=../runtime/production
MI_RUNTIME_LOGS=../runtime/production/logs
MI_RUNTIME_DOCUMENTS=../runtime/production/documents
MI_RUNTIME_UPLOADS=../runtime/production/uploads
MI_RUNTIME_MYSQL=../runtime/production/mysql
MI_RUNTIME_CONFIG=../../backend/config

# --- Workflow Reminder Scheduler ---
MI_SCHEDULER_ENABLED=false
MI_SCHEDULER_INTERVAL_SECONDS=3600
MI_SCHEDULER_LOCK_NAME=workflow:reminder:scheduler
MI_SCHEDULER_REMINDER_TYPE=standard
MI_SCHEDULER_MIN_PENDING_AGE_SECONDS=86400
MI_SCHEDULER_WINDOW_TRUNCATION_SECONDS=86400
