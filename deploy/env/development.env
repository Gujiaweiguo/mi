# =============================================================================
# MI Development Environment Configuration
# =============================================================================
# Usage: This file documents all configurable values for local development.
# The Go backend reads its own config from backend/config/development.yaml.
# This .env file is a centralized reference for developers to find all tunables.

# --- Network ---
MI_SERVER_HOST=0.0.0.0
MI_SERVER_PORT=5180
MI_FRONTEND_DEV_PORT=5173

# --- Database ---
MI_DB_HOST=127.0.0.1
MI_DB_PORT=3306
MI_DB_NAME=mi_dev
MI_DB_USER=mi_dev
MI_DB_PASSWORD=mi_dev
MI_DB_SSL_MODE=disable

# --- Auth ---
MI_JWT_SECRET=change-me-development-secret
MI_JWT_TOKEN_EXPIRY_SECONDS=3600

# --- Logging ---
MI_LOG_LEVEL=debug

# --- Storage (local paths for development) ---
MI_STORAGE_DOCUMENTS=./artifacts/generated-documents
MI_STORAGE_UPLOADS=./artifacts/uploads
MI_STORAGE_LOGS=./artifacts/logs

# --- Workflow Reminder Scheduler ---
MI_SCHEDULER_ENABLED=false
MI_SCHEDULER_INTERVAL_SECONDS=3600
MI_SCHEDULER_LOCK_NAME=workflow:reminder:scheduler
MI_SCHEDULER_REMINDER_TYPE=standard
MI_SCHEDULER_MIN_PENDING_AGE_SECONDS=86400
MI_SCHEDULER_WINDOW_TRUNCATION_SECONDS=86400
